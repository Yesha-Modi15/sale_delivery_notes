<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Use a custom external layout router only from Sale report document -->

    <!-- Inherit web.external_layout and branch only for quotation states -->
    <template id="external_layout_router_quotation" inherit_id="web.external_layout" primary="True">
        <xpath expr="//t[@t-if='company.external_report_layout_id']" position="replace">
            <t t-if="((doc and doc._name == 'sale.order' and doc.state in ('draft', 'sent') and not (env.context.get('proforma') or is_pro_forma)) or (o and o._name == 'sale.order' and o.state in ('draft', 'sent') and not (env.context.get('proforma') or is_pro_forma)))"
               t-call="sale_delivery_notes.external_layout_standard_quotation_only">
                <t t-out="0"/>
            </t>
            <t t-elif="company.external_report_layout_id" t-call="{{company.external_report_layout_id.sudo().key}}">
                <t t-out="0"/>
            </t>
        </xpath>
    </template>

    <template id="report_saleorder_document_quotation_layout_switch" inherit_id="sale.report_saleorder_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="attributes">
            <attribute name="t-call">sale_delivery_notes.external_layout_router_quotation</attribute>
        </xpath>
    </template>

    <!-- Quotation-only variant: Row 1 logo right, Row 2 company address left -->
    <template id="external_layout_standard_quotation_only" inherit_id="web.external_layout_standard" primary="True">
        <!-- First row: empty left + logo right -->
        <xpath expr="//div[contains(@class, 'd-flex') and contains(@class, 'justify-content-between') and contains(@class, 'align-items-center')]"
               position="replace">
            <div class="row mb-2">
                <div class="col-6"/>
                <div class="col-6 text-end">
                    <img t-if="company.logo" class="o_company_logo_small" t-att-src="image_data_uri(company.logo)"
                         alt="Logo"/>
                </div>
            </div>
        </xpath>

        <!-- Second row: company address left + empty right -->
        <xpath expr="//div[@name='company_address']/.." position="replace">
            <div class="row mt-2">
                <div class="col-6" name="company_address">
                    <ul class="list-unstyled" name="company_address_list">
                        <li t-if="company.is_company_details_empty">
                            <span t-field="company.partner_id"
                                  t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'>
                                <div class="bg-light border-1 rounded h-100 d-flex flex-column align-items-center justify-content-center p-4 w-100 opacity-75 text-muted text-center">
                                    <strong>Company address block</strong>
                                    <div>Contains the company address.</div>
                                </div>
                            </span>
                        </li>
                        <li t-else="">
                            <span t-field="company.company_details">
                                <div class="bg-light border-1 rounded h-100 d-flex flex-column align-items-center justify-content-center p-4 w-100 opacity-75 text-muted text-center">
                                    <strong>Company details block</strong>
                                    <div>Contains the company details.</div>
                                </div>
                            </span>
                        </li>
                        <li t-if="not forced_vat"/>
                        <li t-else="">
                            <t t-esc="company.country_id.vat_label or 'Tax ID'">Tax ID</t>:
                            <span t-esc="forced_vat">US12345671</span>
                        </li>
                    </ul>
                </div>
                <div class="col-6"/>
            </div>
        </xpath>

        <!-- Remove default recipient address block from this quotation-only layout -->
        <xpath expr="//t[@t-call='web.address_layout']" position="replace">
            <t/>
        </xpath>

        <!-- Remove the default document title from the layout; it is reprinted in the body -->
        <xpath expr="//h2[@t-out='layout_document_title']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
    </template>

    <!-- Quotation-only body: show customer address and title before informations -->
    <template id="report_saleorder_document_customer_address_body" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[@id='informations']" position="before">
            <t t-if="doc.state in ('draft', 'sent') and not (env.context.get('proforma') or is_pro_forma)">
                <div class="mt-2 mb-3" name="quotation_customer_address_body">
                    <div t-field="doc.partner_id"
                         t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'/>
                </div>
                <div class="mb-3" name="quotation_title_body">
                    <h2 class="mb-0">
                        Quotation #
                        <span t-field="doc.name">SO0000</span>
                    </h2>
                </div>
            </t>
        </xpath>
    </template>


    <template id="report_saleorder_inherit_price_label" inherit_id="sale.report_saleorder_document">

        <!-- Replace "Unit Price" label -->
        <xpath expr="//th[@name='th_priceunit']" position="replace">
            <th name="th_priceunit" class="text-end text-nowrap">
                <t t-if="not (env.context.get('proforma') or is_pro_forma)">
                    Price(
                    <t t-esc="doc.currency_id.name"/>
                    <t t-esc="doc.currency_id.symbol"/>)
                </t>
                <t t-else="">
                    Unit Price
                </t>
            </th>
        </xpath>

        <xpath expr="//th[@name='th_quantity']" position="replace">
            <th name="th_quantity" class="text-end text-nowrap">
                <t t-if="not (env.context.get('proforma') or is_pro_forma)">
                    Qty (<t t-esc="doc.order_line and doc.order_line[0].product_uom.name or ''"/>)
                </t>
                <t t-else="">Qty</t>
            </th>
        </xpath>

        <xpath expr="//td[@name='td_quantity']/span[@t-field='line.product_uom']" position="replace">
            <t t-if="not (env.context.get('proforma') or is_pro_forma)"/>
            <span t-else="" t-field="line.product_uom" groups="uom.group_uom"/>
        </xpath>

        <xpath expr="//td[@name='td_subtotal']/span" position="replace">
            <span t-if="not (env.context.get('proforma') or is_pro_forma)"
                  t-esc="'%.2f' % (line.price_subtotal or 0.0)"/>
            <span t-else="" t-field="line.price_subtotal"
                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
        </xpath>

        <xpath expr="//th[@name='th_subtotal']" position="replace">
            <th name="th_subtotal" class="text-end text-nowrap">
                <t t-if="not (env.context.get('proforma') or is_pro_forma)">
                    Amount (
                    <t t-esc="doc.currency_id.name"/>
                    <t t-esc="doc.currency_id.symbol"/>)
                </t>
                <t t-else="">Amount</t>
            </th>
        </xpath>


    </template>

    <template id="custom_sale_tax_highlight"
              inherit_id="sale.document_tax_totals">

        <xpath expr="//tr[contains(@class, 'o_taxes')]" position="attributes">
            <attribute name="t-att-style">
                "background-color:#e6d9ff !important; -webkit-print-color-adjust:exact; print-color-adjust:exact;" if
                not (env.context.get('proforma') or is_pro_forma) else ''
            </attribute>
        </xpath>

    </template>
</odoo>
